{
  "name": "@taceo/oprf-client",
  "version": "0.0.0",
  "description": "WebSocket client for distributed threshold OPRF over a network of service nodes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TaceoLabs/oprf-client-js",
    "directory": "packages/oprf-client"
  },
  "keywords": [
    "oprf",
    "threshold",
    "websocket",
    "distributed",
    "cryptography",
    "zkp"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@taceo/oprf-client-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
